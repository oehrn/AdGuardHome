# AdGuard Home + Unbound — environment variables
# Copy to .env and adjust. AdGuard Home itself is configured via its YAML
# config (set up via wizard on :3000 after first start), NOT via env vars.
# Only timezone and an optional admin port override live here.

# Timezone (TZ database name, e.g. Europe/Berlin, America/New_York)
TZ=Etc/UTC

# Admin UI port on the host. Default 80. Change if it conflicts with
# another stack on the same host. The initial-setup wizard always uses
# 3000 regardless of this value.
ADGUARD_WEB_PORT=80
